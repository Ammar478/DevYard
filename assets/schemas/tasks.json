{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "devyard://schemas/tasks",
  "title": "TasksFrontmatter",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["tasks"]
    },
    "linked_brd": {
      "type": "string"
    },
    "linked_design": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },
    "generated": {
      "type": "string"
    },
    "count": {
      "type": "integer"
    }
  },
  "required": ["type", "linked_brd", "linked_design", "generated", "count"],
  "additionalProperties": false
}
