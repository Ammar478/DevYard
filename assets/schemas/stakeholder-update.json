{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "devyard://schemas/stakeholder-update",
  "title": "StakeholderUpdateFrontmatter",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["stakeholder-update"]
    },
    "audience": {
      "type": "string",
      "enum": ["team", "leadership", "public", "launch"]
    },
    "cadence": {
      "type": "string",
      "enum": ["weekly", "monthly", "launch", "ad-hoc"]
    },
    "project": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },
    "date": {
      "type": "string"
    },
    "period_start": {
      "type": "string"
    },
    "period_end": {
      "type": "string"
    }
  },
  "required": ["type", "audience", "cadence", "project", "date", "period_start", "period_end"],
  "additionalProperties": false
}
