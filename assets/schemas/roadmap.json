{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "devyard://schemas/roadmap",
  "title": "RoadmapFrontmatter",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["roadmap"]
    },
    "project": {
      "type": "string"
    },
    "updated": {
      "type": "string"
    },
    "audience": {
      "type": "string",
      "enum": ["team", "leadership", "public"]
    }
  },
  "required": ["type", "project", "updated", "audience"],
  "additionalProperties": false
}
