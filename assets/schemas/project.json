{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "devyard://schemas/project",
  "title": "ProjectFrontmatter",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["project"]
    },
    "status": {
      "type": "string",
      "enum": ["created", "active", "parked", "archived"]
    },
    "tier": {
      "type": "string",
      "enum": ["P0", "P1", "P2"]
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_branch": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },
    "last_ticket": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },
    "last_session": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },
    "stack": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created": {
      "type": "string"
    },
    "team": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    }
  },
  "required": [
    "name",
    "type",
    "status",
    "tier",
    "repos",
    "last_branch",
    "last_ticket",
    "last_session",
    "stack",
    "created",
    "team"
  ],
  "additionalProperties": false
}
