{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "devyard://schemas/session",
  "title": "SessionFrontmatter",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["session"]
    },
    "project": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "ticket": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },
    "branch": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },
    "outcome": {
      "type": "string",
      "enum": ["success", "blocked", "wip"]
    },
    "role": {
      "type": "string"
    }
  },
  "required": ["type", "project", "date", "ticket", "branch", "outcome", "role"],
  "additionalProperties": false
}
