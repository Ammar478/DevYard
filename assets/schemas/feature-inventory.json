{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "devyard://schemas/feature-inventory",
  "title": "FeatureInventoryFrontmatter",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["feature-inventory"]
    },
    "project": {
      "type": "string"
    },
    "generated": {
      "type": "string"
    },
    "axes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "http-routes",
          "data-models",
          "async-jobs",
          "test-names",
          "ui-screens",
          "documented-features"
        ]
      }
    }
  },
  "required": ["type", "project", "generated", "axes"],
  "additionalProperties": false
}
